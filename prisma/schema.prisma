generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String             @id @default(uuid())
  email     String             @unique
  name      String
  password  String
  theme     String             @default("light")
  createdAt DateTime           @default(now())
  role      String             @default("editor")
  archives  Archive[]
  favorites FavoriteTemplate[]
  reports   Report[]
  uploads   Upload[]
}

model Upload {
  id         String          @id @default(uuid())
  userId     String
  name       String
  size       Int
  status     String          @default("PROCESSING")
  filePath   String
  headers    String[]
  uploadedAt DateTime        @default(now())
  mappings   ColumnMapping[]
  user       User            @relation(fields: [userId], references: [id])
}

model ColumnMapping {
  id           String  @id @default(uuid())
  uploadId     String
  sourceColumn String
  targetField  String
  confidence   Int
  fieldType    String?
  upload       Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)
}

model Report {
  id         String         @id @default(uuid())
  userId     String
  title      String         @default("Untitled Report")
  department String?
  status     String         @default("draft")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id])
  widgets    ReportWidget[]
}

model ReportWidget {
  id        String  @id @default(uuid())
  reportId  String
  widgetId  String
  type      String
  title     String
  dataField String?
  groupBy   String?
  color     String?
  bgStyle   String  @default("default")
  span      Int     @default(1)
  order     Int
  report    Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Archive {
  id          String          @id @default(uuid())
  userId      String
  title       String
  department  String
  widgetCount Int
  source      String
  tags        String[]
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id])
  widgets     ArchiveWidget[]
}

model ArchiveWidget {
  id        String  @id @default(uuid())
  archiveId String
  widgetId  String
  type      String
  title     String
  dataField String?
  groupBy   String?
  color     String?
  bgStyle   String  @default("default")
  span      Int     @default(1)
  order     Int
  archive   Archive @relation(fields: [archiveId], references: [id], onDelete: Cascade)
}

model FavoriteTemplate {
  id         String   @id @default(uuid())
  userId     String
  templateId String
  addedAt    DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, templateId])
}
